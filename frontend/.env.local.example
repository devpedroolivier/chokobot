# Backend FastAPI protegido consumido pelo admin moderno
PANEL_BACKEND_URL=http://localhost:8000

# Segredo usado para criptografar a sessao HTTP-only do admin Next.js
ADMIN_SESSION_SECRET=troque-esta-chave-por-um-segredo-forte

# Fallback opcional para operacao server-to-server sem login interativo
PANEL_AUTH_USERNAME=
PANEL_AUTH_PASSWORD=
