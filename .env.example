# Integracoes externas
ZAPI_TOKEN=changeme
ZAPI_BASE=https://example.z-api.test/instances/instance-id/token/token-id
OPENAI_API_KEY=changeme

# Banco e estado local
DB_PATH=dados/chokobot.db
DATABASE_URL=
REDIS_URL=redis://chokobot-redis:6379/0
STATE_SQLITE_PATH=dados/state_store.db
STATE_BACKEND_FALLBACK_ENABLED=1
OUTBOX_PATH=dados/outbox.jsonl
OUTBOX_EVENTS_PATH=dados/domain_events.jsonl
AI_LEARNINGS_PATH=app/ai/knowledge/learnings.md

# Aplicacao
TZ=America/Sao_Paulo
BOT_TIMEZONE=America/Sao_Paulo
CAFETERIA_URL=http://bit.ly/44ZlKlZ
DOCES_URL=https://bit.ly/doceschoko
CATALOG_LINK=https://bit.ly/presenteschoko
PIX_KEY=Pix 16847366000130
STORE_CLOSED=0
STORE_CLOSED_NOTICE=Aviso padrao de loja fechada

# Quando 0, desliga todas as respostas automaticas (IA, aviso de fechamento, opt-out).
# As mensagens dos clientes continuam sendo gravadas para o painel.
BOT_AUTO_REPLIES_ENABLED=1

# Split HTTP
CONVERSATION_SERVICE_URL=
CONVERSATION_SERVICE_TIMEOUT=10

# Webhook e seguranca
WEBHOOK_SECRET=
WEBHOOK_SECRET_HEADER=X-Webhook-Secret
WEBHOOK_VERIFY_ENABLED=0
WEBHOOK_REPLAY_WINDOW_SECONDS=300
TEST_PHONES=5511888888888
ADMIN_PHONES=
AUTOMATION_DISABLED_PHONES=
PHONE_OPT_OUT_AUTO_RESUME_MINUTES=30
PHONE_OPT_OUT_REACTIVATION_DELAY_SECONDS=1.5

# Painel
PANEL_AUTH_ENABLED=0
PANEL_AUTH_USERNAME=
PANEL_AUTH_PASSWORD=
ADMIN_FRONTEND_URL=http://191.101.235.185:3000
ADMIN_SESSION_SECRET=

# AI e operacao
AI_SAVE_LEARNING_ENABLED=0
HTTP_TIMEOUT_CONNECT=5
HTTP_TIMEOUT_READ=20
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_FACTOR=1
KNOWLEDGE_FAILURE_ALERT_THRESHOLD=5
KNOWLEDGE_FAILURE_ALERT_WINDOW_MINUTES=60
KNOWLEDGE_FAILURE_ALERT_WEBHOOK=

# Agendamento automatico da Trufinha
# Janela de inatividade: da sexta 19h ate segunda 06h (weekday 0=Seg ... 6=Dom).
AI_AUTO_SCHEDULE_ENABLED=1
AI_AUTO_OFF_WEEKDAY=4
AI_AUTO_OFF_HOUR=19
AI_AUTO_OFF_MINUTE=0
AI_AUTO_ON_WEEKDAY=0
AI_AUTO_ON_HOUR=6
AI_AUTO_ON_MINUTE=0

# Atendentes humanos exibidos no painel (nomes separados por virgula).
# Default: Lu
PANEL_ATTENDANTS=Lu
